# ============================================================
# IncidentGuard — variáveis de ambiente (exemplo)
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env — ele está no .gitignore.
# Em produção, use Kubernetes Secrets ou Vault.
# ============================================================

# --- Banco de dados ---
POSTGRES_USER=incidentguard
POSTGRES_PASSWORD=changeme
POSTGRES_DB=incidentguard
DATABASE_URL=postgresql://incidentguard:changeme@postgres:5432/incidentguard

# --- Autenticação JWT ---
# Gere com: openssl rand -hex 32
JWT_SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# --- API Keys de serviços (webhooks) ---
# Gere com: openssl rand -hex 24
ALERTMANAGER_API_KEY=changeme
SECURITY_SCANNER_API_KEY=changeme
FALCO_API_KEY=changeme

# --- Configuração da API ---
API_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000
